# ─────────────────────────────────────────────────────────────
# Parchhai — environment template. Copy to .env and fill values.
# Per-app .env files (apps/api/.env, packages/db/.env) take precedence.
# NEVER commit a real .env — only this .example file.
# ─────────────────────────────────────────────────────────────

# Database — Neon serverless Postgres.
# DATABASE_URL = pooled connection (used by the app at runtime via the Neon adapter).
# DIRECT_URL   = direct (non-pooled) connection, used by Prisma migrate/introspect.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# Auth — JWT secrets (generate with: openssl rand -base64 48)
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# Payments — Razorpay (test mode). Leave blank to use the stub provider.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# File storage — Cloudflare R2 (S3-compatible). Leave blank to use the local stub uploader.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="parchhai-media"
R2_PUBLIC_URL="https://media.parchhai.example"

# Notifications — Resend (email) + MSG91 (SMS OTP). Blank = console stub.
RESEND_API_KEY=""
MSG91_API_KEY=""
NOTIFY_FROM_EMAIL="hello@parchhai.example"

# API
API_PORT="4000"
API_URL="http://localhost:4000"
WEB_ORIGIN="http://localhost:5173"
NODE_ENV="development"

# Frontends (build-time, public)
VITE_API_URL="http://localhost:4000/api/v1"
EXPO_PUBLIC_API_URL="http://localhost:4000/api/v1"
